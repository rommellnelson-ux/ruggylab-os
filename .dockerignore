# .dockerignore – Files excluded from the Docker build context
# Keeps the image small and prevents secrets from leaking into layers.

# Version control
.git
.gitignore
.gitattributes

# Python bytecode & caches
__pycache__
*.pyc
*.pyo
*.pyd
.Python
*.egg-info
dist/
build/
*.egg

# Virtual environments
.venv
venv
env
ENV

# Test artefacts
tests/
.pytest_cache
.coverage
htmlcov/
coverage.xml
*.coveragerc

# Linting / type-checking artefacts
.mypy_cache
.ruff_cache

# Local secrets – NEVER send to Docker daemon
.env
.env.*
!.env.example

# CI / editor
.github
.claude
.vscode
.idea
*.swp
*~

# Dev-only databases and logs
*.db
*.sqlite
*.sqlite3
logs/
*.log

# Security scan reports
bandit_report.txt
pip_audit_report.txt
.secrets.baseline

# Documentation source (not needed at runtime)
docs/
assets/
*.md
!README.md

# Miscellaneous
.DS_Store
Thumbs.db
