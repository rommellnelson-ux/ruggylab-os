APP_NAME=RuggyLab OS
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite:///./ruggylab_os.db
SECRET_KEY=replace_with_a_unique_secret_key_at_least_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=480
FIRST_SUPERUSER=admin
FIRST_SUPERUSER_PASSWORD=replace_with_a_strong_admin_password
FIRST_SUPERUSER_FULL_NAME=RuggyLab Administrator
ENABLE_DH36_LISTENER=false
TESTING=false
POSTGRES_USER=admin
POSTGRES_PASSWORD=replace_with_a_database_password
POSTGRES_DB=ruggylab_os
PGADMIN_EMAIL=admin@ruggylab.local
PGADMIN_PASSWORD=replace_with_a_pgadmin_password
