# ============================================================================
# RuggyLab OS - Environment Configuration Example
# ============================================================================
# Copy this file to .env and update the values for your environment.
# For production, use secure secret management services (AWS Secrets Manager,
# Azure Key Vault, Google Secret Manager, etc.) instead of storing secrets 
# in .env files.
# ============================================================================

# ============================================================================
# SECURITY - CRITICAL FOR PRODUCTION
# ============================================================================
# Generate secure secrets using:
#   SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
#   FIRST_SUPERUSER_PASSWORD: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 
# For production, set these via environment variables from your secrets manager.
# The .env file should only be used for local development.
SECRET_KEY=CHANGE_ME_min_32_chars_use_python_secrets_token_hex_32
FIRST_SUPERUSER_PASSWORD=CHANGE_ME_strong_password_min_16_chars

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_NAME=RuggyLab OS
APP_VERSION=0.7.4
API_V1_PREFIX=/api/v1

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Examples:
#   SQLite (dev):      sqlite:///./ruggylab_os.db
#   PostgreSQL (prod via docker-compose): postgresql+psycopg://ruggylab:CHANGE_ME@postgres:5432/ruggylab
#   PostgreSQL (external): postgresql+psycopg://user:password@host:5432/ruggylab
DATABASE_URL=postgresql+psycopg://ruggylab:CHANGE_ME@postgres:5432/ruggylab  # pragma: allowlist secret

# PostgreSQL credentials (used by the postgres Docker service)
# Must match the user/password embedded in DATABASE_URL above.
POSTGRES_USER=ruggylab
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=ruggylab

# ============================================================================
# JWT & AUTHENTICATION
# ============================================================================
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ============================================================================
# INITIAL SUPERUSER CONFIGURATION
# ============================================================================
# These values are only used during the first application startup
# to bootstrap the initial admin user. Change them in production.
FIRST_SUPERUSER=admin
FIRST_SUPERUSER_FULL_NAME=RuggyLab Administrator

# ============================================================================
# DH36 LISTENER (MLLP Protocol Listener for lab equipment)
# ============================================================================
ENABLE_DH36_LISTENER=false
DH36_LISTENER_HOST=127.0.0.1
DH36_LISTENER_PORT=5001

# ============================================================================
# ANALYZER MIDDLEWARE INGESTION (ASTM TCP driver -> FastAPI REST)
# ============================================================================
# Use a long random value; rotate it if the middleware PC is replaced.
ANALYZER_API_KEY=replace_with_a_long_random_middleware_key
# Optional allowlist. Empty list means rely on firewall/VLAN and API/HMAC auth.
# Example for one middleware PC: ANALYZER_ALLOWED_IPS=["192.168.10.50"]
ANALYZER_ALLOWED_IPS=[]
# Optional HMAC signing. Set on both FastAPI and scripts/astm_tcp_driver.py.
ANALYZER_HMAC_SECRET=replace_with_a_long_random_hmac_secret
ANALYZER_SIGNATURE_MAX_SKEW_SECONDS=300
# Local transactional outbox used by scripts/astm_tcp_driver.py (SQLite WAL).
ASTM_OUTBOX_DB=artifacts/astm_outbox.sqlite3
ASTM_DISPATCH_INTERVAL_SECONDS=5

# ============================================================================
# DATA & STORAGE DIRECTORIES
# ============================================================================
BASE_DATA_DIR=data
MICROSCOPY_STORAGE_DIR=data/microscopy
MALARIA_MODEL_PATH=models/malaria_mobilenetv2
MALARIA_ANALYSIS_AUTORUN=true

# ============================================================================
# TESTING
# ============================================================================
TESTING=false

# ============================================================================
# RESULT REPORT RELEASE POLICY
# ============================================================================
# Default false: allows provisional report release when staffing does not allow
# daily double validation. Critical values still require acknowledgement.
# Set true to enforce strict validation before report release/signature.
REQUIRE_VALIDATION_FOR_RELEASE=false

# ============================================================================
# UAT / VALIDATION SCRIPTS
# ============================================================================
# Les scripts scripts/*_uat_playwright.js créent des patients, échantillons et
# résultats de test. Les exécuter uniquement sur une base dev/staging dédiée.
UAT_BASE_URL=http://127.0.0.1:8000
# UAT_USERNAME=admin
# UAT_PASSWORD=change_me_only_on_dev

# ============================================================================
# REPORT DELIVERY OUTBOX
# ============================================================================
# Dossiers de sortie pour les canaux patient_portal/filesystem et fhir.
REPORT_DELIVERY_OUTPUT_DIR=data/report_delivery/pdf
REPORT_DELIVERY_FHIR_DIR=data/report_delivery/fhir

# SMTP réel pour les canaux email/prescriber. Sans destinataire, l'événement
# reste en retry/dead-letter au lieu d'être marqué envoyé artificiellement.
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_FROM=alertes@ruggylab.local
SMTP_STARTTLS=false
# SMTP_USERNAME=
# SMTP_PASSWORD=
# REPORT_DELIVERY_EMAIL_TO=biologiste@example.org

# ============================================================================
# RATE LIMITING AND ABUSE PROTECTION
# ============================================================================
# Controls the built-in IP-based request throttling for production.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_BLOCK_SECONDS=60

# Login-specific brute-force protection.
LOGIN_RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT_REQUESTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
LOGIN_RATE_LIMIT_BLOCK_SECONDS=300

# Optional Redis backend for future cache or rate limit persistence.
# If unset, the application uses an in-memory per-process fallback.
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# HTTP SECURITY HEADERS
# ============================================================================
SECURITY_HEADERS_ENABLED=true
HSTS_ENABLED=true
HSTS_MAX_AGE_SECONDS=63072000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true
REFERRER_POLICY=no-referrer
FRAME_OPTIONS=DENY
PERMISSIONS_POLICY=geolocation=(), microphone=(), camera=()

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
CORS_ENABLED=true
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# ============================================================================
# USER QUOTA PROTECTION
# ============================================================================
USER_QUOTA_ENABLED=true
USER_QUOTA_REQUESTS=1000
USER_QUOTA_WINDOW_SECONDS=3600
USER_QUOTA_BLOCK_SECONDS=3600

# ============================================================================
# PHASE 3: PERFORMANCE (CACHING, PAGINATION, COMPRESSION)
# ============================================================================

# Caching settings
CACHE_ENABLED=true
CACHE_DEFAULT_TTL_SECONDS=300
CACHE_BACKEND=memory

# Compression settings
COMPRESSION_ENABLED=true
COMPRESSION_MIN_SIZE_BYTES=500

# Pagination settings
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ============================================================================
# GRAFANA
# ============================================================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME

# ============================================================================
# REVERSE PROXY (Caddy) — seul service exposé (80/443)
# ============================================================================
# Domaine ou nom d'hôte servi par le proxy TLS devant l'app. En dev : localhost.
RUGGYLAB_DOMAIN=localhost

# ============================================================================
# PGADMIN (Development only)
# ============================================================================
PGADMIN_EMAIL=admin@ruggylab.local
PGADMIN_PASSWORD=replace_with_a_pgadmin_password

# ============================================================================
# CLOUD SECRET MANAGEMENT (Optional - for production)
# ============================================================================
# Uncomment and configure ONE of these for secure secret management

# --- AWS Secrets Manager ---
# SECRET_MANAGER_TYPE=aws
# AWS_REGION=us-east-1
# AWS_SECRET_NAME=ruggylab/prod/secrets

# --- Azure Key Vault ---
# SECRET_MANAGER_TYPE=azure
# AZURE_KEYVAULT_URL=https://<vault-name>.vault.azure.net/
# AZURE_TENANT_ID=<tenant-id>
# AZURE_CLIENT_ID=<client-id>
# AZURE_CLIENT_SECRET=<client-secret>

# --- Google Cloud Secret Manager ---
# SECRET_MANAGER_TYPE=gcp
# GCP_PROJECT_ID=<project-id>
# GCP_SECRET_NAME=ruggylab-prod-secrets
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
